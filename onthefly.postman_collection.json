{
  "info": {
    "name": "On the Fly API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" }
  ],
  "item": [
    {
      "name": "Trips",
      "item": [
        { "name": "Get all trips", "request": { "method": "GET", "url": "{{baseUrl}}/trips" } },
        { "name": "Get trip by id", "request": { "method": "GET", "url": "{{baseUrl}}/trips/1" } },
        {
          "name": "Create trip",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/trips",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Trip\",\n  \"description\": \"A test trip\",\n  \"img_url\": \"http://x.com/a.jpg\",\n  \"num_days\": 3,\n  \"start_date\": \"2026-08-01\",\n  \"end_date\": \"2026-08-04\",\n  \"total_cost\": 500\n}"
            }
          }
        },
        {
          "name": "Update trip",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/trips/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Trip\",\n  \"description\": \"Updated desc\",\n  \"img_url\": \"http://x.com/a.jpg\",\n  \"num_days\": 4,\n  \"start_date\": \"2026-08-01\",\n  \"end_date\": \"2026-08-05\",\n  \"total_cost\": 600\n}"
            }
          }
        },
        { "name": "Delete trip", "request": { "method": "DELETE", "url": "{{baseUrl}}/trips/1" } }
      ]
    },
    {
      "name": "Destinations",
      "item": [
        { "name": "Get all destinations", "request": { "method": "GET", "url": "{{baseUrl}}/destinations" } },
        { "name": "Get destination by id", "request": { "method": "GET", "url": "{{baseUrl}}/destinations/1" } },
        {
          "name": "Create destination",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/destinations",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"Eiffel Tower\",\n  \"description\": \"Iconic Paris landmark\",\n  \"city\": \"Paris\",\n  \"country\": \"France\",\n  \"img_url\": \"http://x.com/a.jpg\",\n  \"flag_img_url\": \"http://x.com/flag.jpg\"\n}"
            }
          }
        },
        {
          "name": "Update destination",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/destinations/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"Updated Destination\",\n  \"description\": \"Updated desc\",\n  \"city\": \"Paris\",\n  \"country\": \"France\",\n  \"img_url\": \"http://x.com/a.jpg\",\n  \"flag_img_url\": \"http://x.com/flag.jpg\"\n}"
            }
          }
        },
        { "name": "Delete destination", "request": { "method": "DELETE", "url": "{{baseUrl}}/destinations/1" } }
      ]
    },
    {
      "name": "Activities",
      "item": [
        { "name": "Get all activities", "request": { "method": "GET", "url": "{{baseUrl}}/activities" } },
        { "name": "Get activities for trip", "request": { "method": "GET", "url": "{{baseUrl}}/activities/1" } },
        {
          "name": "Create activity for trip",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/activities/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activity\": \"Blackjack at Caesar's Palace\"\n}"
            }
          }
        },
        { "name": "Upvote activity", "request": { "method": "PATCH", "url": "{{baseUrl}}/activities/1" } },
        { "name": "Delete activity", "request": { "method": "DELETE", "url": "{{baseUrl}}/activities/1" } }
      ]
    },
    {
      "name": "Trips-Destinations",
      "item": [
        { "name": "Get all trips-destinations", "request": { "method": "GET", "url": "{{baseUrl}}/trips-destinations" } },
        { "name": "Get trips for destination", "request": { "method": "GET", "url": "{{baseUrl}}/trips-destinations/trips/1" } },
        { "name": "Get destinations for trip", "request": { "method": "GET", "url": "{{baseUrl}}/trips-destinations/destinations/1" } },
        {
          "name": "Link trip to destination",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/trips-destinations",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trip_id\": 1,\n  \"destination_id\": 1\n}"
            }
          }
        }
      ]
    }
  ]
}